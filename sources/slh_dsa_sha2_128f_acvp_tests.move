/// NIST ACVP test vectors for SLH-DSA-SHA2-128f signature verification.
///
/// Source: NIST ACVP Server (gen-val/json-files/SLH-DSA-sigVer-FIPS205)
/// https://github.com/usnistgov/ACVP-Server
///
/// 14 test vectors: 2 valid, 12 invalid
/// signatureInterface: internal (FIPS 205 Algorithm 22, `slh_verify_internal`)
#[test_only]
module fips205::slh_dsa_sha2_128f_acvp_tests {
    use fips205::slh_dsa;
    use fips205::params;

    /// ACVP tc169: modified R (randomness)
    #[test]
    fun test_acvp_tc169_modified_r() {
        let pk = x"C5A8E9EC36E802796D616FBE035AD7F42EE510C22709664DC258536C1613E4A6";
        let msg = x"";
        let sig = x"";
        assert!(!slh_dsa::verify_internal(&msg, &sig, &pk, &params::sha2_128f()));
    }

