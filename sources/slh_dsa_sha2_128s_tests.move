#[test_only]
module fips205::slh_dsa_sha2_128s_tests {
    use fips205::slh_dsa_sha2_128s;

    #[test]
    fun test_verify_valid_signature() {
        let pk = x"020102030405060708090a0b0c0d0e0f233f6f5acdb1b85f8d570b3822629c53";
        let msg = x"74657374206d657373616765";
        let sig = x"";
        assert!(slh_dsa_sha2_128s::verify(&msg, &sig, &pk));
    }

    #[test]
    fun test_verify_wrong_message() {
        let pk = x"020102030405060708090a0b0c0d0e0f233f6f5acdb1b85f8d570b3822629c53";
        let msg = x"0000000000000000";
        let sig = x"";
        assert!(!slh_dsa_sha2_128s::verify(&msg, &sig, &pk));
    }

    #[test]
    fun test_verify_bad_pk_length() {
        let pk = x"0102030405";
        let msg = x"74657374206d657373616765";
        let sig = x"";
        assert!(!slh_dsa_sha2_128s::verify(&msg, &sig, &pk));
    }

    #[test]
    fun test_verify_bad_sig_length() {
        let pk = x"020102030405060708090a0b0c0d0e0f233f6f5acdb1b85f8d570b3822629c53";
        let msg = x"74657374206d657373616765";
        let sig = x"0102030405";
        assert!(!slh_dsa_sha2_128s::verify(&msg, &sig, &pk));
    }
}
