#[test_only]
module fips205::slh_dsa_sha2_128f_tests {
    use fips205::slh_dsa_sha2_128f;

    #[test]
    fun test_verify_valid_signature() {
        let pk = x"020102030405060708090a0b0c0d0e0f7927093c1ee22ed39dc27cbddc343dd5";
        let msg = x"74657374206d657373616765";
        let sig = x"";
        assert!(slh_dsa_sha2_128f::verify(&msg, &sig, &pk));
    }

    #[test]
    fun test_verify_wrong_message() {
        let pk = x"020102030405060708090a0b0c0d0e0f7927093c1ee22ed39dc27cbddc343dd5";
        let msg = x"0000000000000000";
        let sig = x"";
        assert!(!slh_dsa_sha2_128f::verify(&msg, &sig, &pk));
    }

    #[test]
    fun test_verify_bad_pk_length() {
        let pk = x"0102030405";
        let msg = x"74657374206d657373616765";
        let sig = x"0102030405";
        assert!(!slh_dsa_sha2_128f::verify(&msg, &sig, &pk));
    }

    #[test]
    fun test_verify_bad_sig_length() {
        let pk = x"020102030405060708090a0b0c0d0e0f7927093c1ee22ed39dc27cbddc343dd5";
        let msg = x"74657374206d657373616765";
        let sig = x"0102030405";
        assert!(!slh_dsa_sha2_128f::verify(&msg, &sig, &pk));
    }
}
